{
  "manifest_version": 3,
  "name": "AgentSphere",
  "version": "1.0",
  "description": "Bridges AgentSphere AI with your browser for automated operations",
  "permissions": ["tabs", "scripting", "storage", "activeTab", "alarms", "debugger", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "run_at": "document_idle",
    "js": ["content.js"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon-128.png"
  }
}
